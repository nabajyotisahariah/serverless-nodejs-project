Using Serverless Framework with Express.js is one of the best ways to run an existing Node.js API on AWS Lambda with minimal changes.
$ cat serverless.yml

functions:
  api:					#Lambda function named:	
    handler: handler.handler		#File name = handler.js, Exported function = handler
    events:
      - httpApi: "*"				#Connect Lambda to HTTP API Gateway.


$ cat handler.js

#converts Express app into Lambda handler, Because Lambda doesn’t understand Express directly. 
const serverless = require("serverless-http");  

 #express = web framework      
const express = require("express");	    
const app = express();

app.get("/", (req, res, next) => {
  return res.status(200).json({
    message: "Hello from root!",
  });
});

app.get("/hello", (req, res, next) => {
  return res.status(200).json({
    message: "Hello from path!",
  });
});
exports.handler = serverless(app);


